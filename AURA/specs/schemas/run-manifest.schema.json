{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:spec:vendor-neutral-asset-discovery-elt:run-manifest:1.0.0",
  "title": "Discovery Run Manifest",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "typed_error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "severity"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "severity": { "type": "string", "enum": ["debug", "info", "warning", "error", "critical"] },
        "details": { "type": "object", "additionalProperties": true }
      }
    }
  },
  "required": [
    "schema_version",
    "run_id",
    "tenant_ref",
    "zone_ref",
    "trigger",
    "target_set",
    "scan_profile",
    "started_at",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "run_id": {
      "type": "string",
      "minLength": 8,
      "description": "ULID or UUIDv7 preferred."
    },
    "tenant_ref": { "type": "string", "minLength": 1 },
    "zone_ref": { "type": "string", "minLength": 1 },
    "trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["schedule", "adhoc", "api", "replay"] },
        "requested_by": { "type": "string" },
        "request_id": { "type": "string" }
      }
    },
    "target_set": {
      "type": "object",
      "additionalProperties": false,
      "required": ["targets_hash", "targets"],
      "properties": {
        "targets_hash": {
          "type": "string",
          "description": "Hash of the canonicalized targets list (stable ordering)."
        },
        "targets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "value"],
            "properties": {
              "type": { "type": "string", "enum": ["cidr", "ip_range", "ip", "hostname"] },
              "value": { "type": "string", "minLength": 1 },
              "labels": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "scan_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "mode"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "mode": { "type": "string", "enum": ["tcp", "udp", "tcp_udp"] },
        "port_spec": {
          "type": "string",
          "description": "Port expression (scanner-specific) but recorded verbatim."
        },
        "service_fingerprinting": { "type": "boolean", "default": true },
        "os_fingerprinting": { "type": "boolean", "default": false },
        "timing_template": {
          "type": "string",
          "enum": ["paranoid", "sneaky", "polite", "normal", "aggressive", "insane"]
        },
        "max_runtime_seconds": { "type": "integer", "minimum": 1 }
      }
    },
    "sharding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["shard_count"],
      "properties": {
        "shard_count": { "type": "integer", "minimum": 1 },
        "strategy": {
          "type": "string",
          "enum": ["cidr_split", "range_chunk", "hostname_chunk", "mixed"]
        },
        "shards": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["shard_id", "targets"],
            "properties": {
              "shard_id": { "type": "string", "minLength": 1 },
              "targets": { "$ref": "#/properties/target_set/properties/targets" }
            }
          }
        }
      }
    },
    "scanner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "description": "e.g., nmap, masscan, custom" },
        "version": { "type": "string" },
        "arguments": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Recorded verbatim for reproducibility."
        }
      }
    },
    "started_at": { "type": "string", "format": "date-time" },
    "ended_at": { "type": "string", "format": "date-time" },
    "status": { "type": "string", "enum": ["running", "succeeded", "failed", "partial"] },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "raw_prefix_uri": { "type": "string", "minLength": 1, "description": "GCS prefix for raw artifacts." },
        "manifest_uri": { "type": "string", "minLength": 1, "description": "URI of this manifest in storage." }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": true,
      "description": "Free-form but should include counts and error rates; consumer must not depend on specific keys."
    },
    "errors": {
      "type": "array",
      "items": { "$ref": "#/$defs/typed_error" }
    }
  }
}
