{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:spec:vendor-neutral-asset-discovery-elt:pipeline-event:1.0.0",
  "title": "Pipeline Contract Event Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "event_type",
    "emitted_at",
    "run_id",
    "tenant_ref",
    "zone_ref",
    "stage",
    "payload"
  ],
  "$defs": {
    "typed_error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "severity", "retryable"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "severity": { "type": "string", "enum": ["debug", "info", "warning", "error", "critical"] },
        "retryable": { "type": "boolean" },
        "details": { "type": "object", "additionalProperties": true }
      }
    }
  },
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "event_id": { "type": "string", "minLength": 8 },
    "event_type": { "type": "string", "minLength": 1 },
    "emitted_at": { "type": "string", "format": "date-time" },
    "run_id": { "type": "string", "minLength": 8 },
    "tenant_ref": { "type": "string", "minLength": 1 },
    "zone_ref": { "type": "string", "minLength": 1 },
    "stage": {
      "type": "string",
      "enum": ["orchestrate", "scan_shard", "normalize_validate", "entity_resolve_merge", "compute_changes"]
    },
    "payload": {
      "type": "object",
      "additionalProperties": true,
      "description": "Event-specific payload; validated by event_type-specific schema when provided."
    },
    "errors": {
      "type": "array",
      "items": { "$ref": "#/$defs/typed_error" }
    }
  }
}
