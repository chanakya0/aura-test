{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:spec:vendor-neutral-asset-discovery-elt:asset-change:1.0.0",
  "title": "Asset Change Event",
  "description": "Computed change between two consecutive canonical asset versions for reporting and auditing.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "change_id",
    "tenant_ref",
    "zone_ref",
    "asset_id",
    "run_id",
    "observed_at",
    "change_type",
    "diff",
    "evidence"
  ],
  "$defs": {
    "typed_error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "severity"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "severity": { "type": "string", "enum": ["debug", "info", "warning", "error", "critical"] },
        "details": { "type": "object", "additionalProperties": true }
      }
    },
    "evidence_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id", "observation_id", "observed_at"],
      "properties": {
        "run_id": { "type": "string", "minLength": 8 },
        "shard_id": { "type": "string" },
        "observation_id": { "type": "string", "minLength": 8 },
        "observed_at": { "type": "string", "format": "date-time" },
        "raw_uri": { "type": "string", "minLength": 1 }
      }
    }
  },
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "change_id": { "type": "string", "minLength": 8, "description": "ULID/UUIDv7; unique per change event." },
    "tenant_ref": { "type": "string", "minLength": 1 },
    "zone_ref": { "type": "string", "minLength": 1 },
    "asset_id": { "type": "string", "minLength": 8 },
    "run_id": { "type": "string", "minLength": 8 },
    "observed_at": { "type": "string", "format": "date-time", "description": "Timestamp of the run that produced this change." },
    "change_type": {
      "type": "string",
      "enum": ["created", "updated", "deactivated", "reactivated"]
    },
    "prior": {
      "type": "object",
      "additionalProperties": true,
      "description": "Optional prior asset snapshot (JSON), if stored for convenience."
    },
    "current": {
      "type": "object",
      "additionalProperties": true,
      "description": "Optional current asset snapshot (JSON), if stored for convenience."
    },
    "diff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "changes"],
      "properties": {
        "format": { "type": "string", "enum": ["field_list", "json_patch"] },
        "changes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "op"],
            "properties": {
              "path": { "type": "string", "minLength": 1, "description": "JSON pointer-like path to field." },
              "op": { "type": "string", "enum": ["add", "remove", "replace"] },
              "from": {},
              "to": {},
              "semantic_type": {
                "type": "string",
                "enum": ["identity", "address", "service", "attribute", "label", "state", "evidence", "other"]
              }
            }
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/evidence_ref" }
    },
    "errors": {
      "type": "array",
      "items": { "$ref": "#/$defs/typed_error" }
    }
  }
}
