{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:spec:vendor-neutral-asset-discovery-elt:asset:1.0.0",
  "title": "Canonical Asset",
  "description": "A canonical, vendor-neutral asset entity produced by deterministic entity resolution and merge rules.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "asset_id",
    "tenant_ref",
    "zone_ref",
    "first_seen",
    "last_seen",
    "active",
    "identity",
    "evidence"
  ],
  "$defs": {
    "ip": {
      "type": "string",
      "pattern": "^(?:\\d{1,3}\\.){3}\\d{1,3}$|^[0-9a-fA-F:]+$"
    },
    "mac": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{2}(:[0-9a-fA-F]{2}){5}$"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "evidence_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id", "observation_id", "observed_at"],
      "properties": {
        "run_id": { "type": "string", "minLength": 8 },
        "shard_id": { "type": "string" },
        "observation_id": { "type": "string", "minLength": 8 },
        "observed_at": { "type": "string", "format": "date-time" },
        "raw_uri": { "type": "string", "minLength": 1 }
      }
    }
  },
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "asset_id": {
      "type": "string",
      "minLength": 8,
      "description": "Stable deterministic ID derived from highest-confidence identity keys per dedup rules."
    },
    "tenant_ref": { "type": "string", "minLength": 1 },
    "zone_ref": { "type": "string", "minLength": 1 },
    "first_seen": { "type": "string", "format": "date-time" },
    "last_seen": { "type": "string", "format": "date-time" },
    "active": { "type": "boolean" },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["names", "addresses"],
      "properties": {
        "names": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["value", "kind"],
            "properties": {
              "kind": { "type": "string", "enum": ["hostname", "dns", "netbios", "fqdn", "other"] },
              "value": { "type": "string", "minLength": 1 },
              "first_seen": { "type": "string", "format": "date-time" },
              "last_seen": { "type": "string", "format": "date-time" },
              "confidence": { "$ref": "#/$defs/confidence" }
            }
          }
        },
        "addresses": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["ip"],
            "properties": {
              "ip": { "$ref": "#/$defs/ip" },
              "mac": { "$ref": "#/$defs/mac" },
              "first_seen": { "type": "string", "format": "date-time" },
              "last_seen": { "type": "string", "format": "date-time" },
              "confidence": { "$ref": "#/$defs/confidence" },
              "source_hints": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["protocol", "port"],
        "properties": {
          "protocol": { "type": "string", "enum": ["tcp", "udp", "sctp", "icmp", "other"] },
          "port": { "type": "integer", "minimum": 0, "maximum": 65535 },
          "states": {
            "type": "array",
            "items": { "type": "string", "enum": ["open", "closed", "filtered", "open|filtered", "unknown"] }
          },
          "service_name": { "type": "string" },
          "product": { "type": "string" },
          "version": { "type": "string" },
          "cpe": { "type": "array", "items": { "type": "string" } },
          "first_seen": { "type": "string", "format": "date-time" },
          "last_seen": { "type": "string", "format": "date-time" },
          "evidence": {
            "type": "array",
            "items": { "$ref": "#/$defs/evidence_ref" }
          }
        }
      }
    },
    "attributes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "os": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string" },
            "confidence": { "$ref": "#/$defs/confidence" }
          }
        },
        "device_type": { "type": "string", "enum": ["server", "workstation", "network_device", "iot", "printer", "unknown"] },
        "vendor": { "type": "string" }
      }
    },
    "labels": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/evidence_ref" },
      "description": "Evidence refs used to justify and trace the current asset state."
    },
    "resolution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "strategy": { "type": "string", "enum": ["deterministic_rules"] },
        "primary_key": { "type": "string", "description": "Which identity key class anchored asset_id." },
        "explanations": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
